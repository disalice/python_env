{
  "name": "Python uv Development Container",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "settings": {
        // 固定パスではなく変数を使用
        "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
        "python.analysis.extraPaths": ["${containerWorkspaceFolder}/src"],
        "python.testing.pytestEnabled": true
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "ms-python.vscode-pylance"
      ]
    }
  },
  // コンテナ起動時に、マウントされたフォルダの絶対パスを動的に注入
  "remoteEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}/src"
  },
  // 開発コンテナ内ではすべてのツール（dev, web, data）を使えるようにフル同期
  "postCreateCommand": "uv sync --all-groups",
  "remoteUser": "vscode"
}